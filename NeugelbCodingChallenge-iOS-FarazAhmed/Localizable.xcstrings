            "state" : "translated",
            "value" : "Laufzeit %@"
          }
        }
      }
    },
    "Search movies" : {
      "comment" : "A placeholder for a search bar.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filme suchen"
          }
        }
      }
    },
    "search.min_characters" : {
      "comment" : "Hint shown in the search idle state.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib mindestens zwei Zeichen ein, um zu suchen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Type at least two characters to search."
          }
        }
      }
    },
    "search.suggestions_label" : {
      "comment" : "Accessibility label describing the search suggestions.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suchvorschläge"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Search suggestions"
          }
        }
      }
    },
    "Something went wrong. Please try again." : {
      "comment" : "Error message displayed when an unknown error occurs.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etwas ist schiefgelaufen. Bitte versuche es erneut."
          }
        }
      }
    },
    "The movie database is currently unavailable. Try again in a moment." : {
      "comment" : "Error message when the movie database is unavailable.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Filmdatenbank ist derzeit nicht verfügbar. Versuche es gleich noch einmal."
          }
        }
      }
    },
    "This movie could not be found." : {
      "comment" : "Error message when a movie is not found.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Film wurde nicht gefunden."
          }
        }
      }
    },
    "token_entry.access_token_label" : {
      "comment" : "Field label / section header for the TMDB access token.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TMDB-Zugriffstoken"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TMDB Access Token"
          }
        }
      }
    },
    "token_entry.instructions" : {
      "comment" : "Footer explaining how to obtain and store the token.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge deinen TMDB API Read Access Token (v4) ein, um Filme zu laden. Er wird sicher im Schlüsselbund gespeichert. Einen kostenlosen Token erhältst du unter themoviedb.org/settings/api."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paste your TMDB API Read Access Token (v4) to load movies. It is stored securely in the Keychain. You can create a free token at themoviedb.org/settings/api."
          }
        }
      }
    },
    "token_entry.save" : {
      "comment" : "Button that saves the entered token.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sichern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save"
          }
        }
      }
    },
    "token_entry.title" : {
      "comment" : "Navigation title of the token entry screen.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Willkommen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome"
          }
        }
      }
    },
    "Try Again" : {
      "comment" : "Button title for the \"Try Again\" action.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erneut versuchen"
          }
        }
      }
    },
    "You appear to be offline. Check your connection and try again." : {
      "comment" : "Error message when the user is offline.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du scheinst offline zu sein. Prüfe deine Verbindung und versuche es erneut."
          }
        }
      }
    },
    "Your TMDB access token was rejected. Please update it." : {
      "comment" : "Error message when the TMDB access token is rejected.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein TMDB-Zugriffstoken wurde abgelehnt. Bitte aktualisiere ihn."
          }
        }
      }
    }
  },
  "version" : "1.0"
}